enum RoadmapStage {
  IDEA
  BACKLOG
  PLANNED
  IN_PROGRESS
  SHIPPED
  DECLINED
}

model RoadmapItem {
  id                 Int          @id @default(autoincrement())
  uid                String       @unique @default(cuid())
  title              String
  description        String
  acceptanceCriteria String?
  stage              RoadmapStage @default(IDEA)

  focusArea String?
  type      String?
  tags      String[] @default([])
  order     Float    @default(99)

  createdByUid String
  createdBy    Member @relation("roadmapItemCreatedBy", fields: [createdByUid], references: [uid])

  promotedAt     DateTime?
  promotedByUid  String?
  promotedBy     Member?   @relation("roadmapItemPromotedBy", fields: [promotedByUid], references: [uid])
  declinedReason String?

  externalTrackerUrl String?

  objectiveUid String?
  objective    RoadmapObjective? @relation(fields: [objectiveUid], references: [uid])

