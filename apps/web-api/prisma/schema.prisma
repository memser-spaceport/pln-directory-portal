model RoadmapItemUpvote {
  id        Int         @id @default(autoincrement())
  uid       String      @unique @default(cuid())
  itemUid   String
  item      RoadmapItem @relation(fields: [itemUid], references: [uid], onDelete: Cascade)
  memberUid String
  member    Member      @relation("roadmapItemUpvoter", fields: [memberUid], references: [uid])
  note      String?
  createdAt DateTime    @default(now())

  @@unique([itemUid, memberUid])
  @@index([memberUid])
}

/// Scarce priority pin. Active while releasedAt is null; releasedAt is set when the
/// pin auto-returns to the member's budget (item enters a non-pinnable stage or is
/// archived). Released rows are kept as history for frozen counts and admin views.
/// Uniqueness of (itemUid, memberUid) is enforced only for active pins via a partial
/// unique index added in the migration (Prisma cannot express partial indexes):
///   CREATE UNIQUE INDEX "RoadmapItemPin_active_item_member_key"
///     ON "RoadmapItemPin"("itemUid", "memberUid") WHERE "releasedAt" IS NULL;
model RoadmapItemPin {
  id         Int         @id @default(autoincrement())
  uid        String      @unique @default(cuid())
  itemUid    String
  item       RoadmapItem @relation(fields: [itemUid], references: [uid], onDelete: Cascade)
  memberUid  String
  member     Member      @relation("roadmapItemPinner", fields: [memberUid], references: [uid])
  note       String?
  releasedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([itemUid, releasedAt])
  @@index([memberUid, releasedAt])
}

model RoadmapObjective {
  id           Int           @id @default(autoincrement())
  uid          String        @unique @default(cuid())
  title        String        @unique
  order        Int           @unique @default(autoincrement())
  createdByUid String?
  createdBy    Member?       @relation("roadmapObjectiveCreatedBy", fields: [createdByUid], references: [uid])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  items        RoadmapItem[]
}

/// Server-persisted snapshot of a member's in-progress Gantry create/submit form, so
/// the draft follows them across devices and browsers. At most one active draft per
/// member (unique memberUid). Payload fields are nullable — this is partial, unsaved
/// form state, not a validated item. `variant` is "idea" | "roadmap"; `stage` mirrors
/// RoadmapStage but is stored loosely as a string since it is unsubmitted form input.
model RoadmapSubmissionDraft {
  id        Int    @id @default(autoincrement())
  uid       String @unique @default(cuid())
  memberUid String @unique
  member    Member @relation("roadmapSubmissionDraftOwner", fields: [memberUid], references: [uid], onDelete: Cascade)

  variant             String   @default("idea")
  title               String?
  description         String?
  tags                String[] @default([])
  type                String?
  stage               String?
  objectiveUid        String?
  newObjectiveTitle   String?
  showCreateObjective Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Single-row table (id = 1) holding roadmap-wide configuration.
model RoadmapSettings {
  id           Int      @id @default(1)
  pinLimit     Int      @default(3)
  updatedByUid String?
  updatedAt    DateTime @updatedAt
}

// ── AI Apps (PL Infra) ─────────────────────────────────────────────────────
// POC: PLN members vibe-code an app locally with our starter kit, then their AI
// agent deploys it to our sandbox runner. We track each app + its deploy status.

enum AiAppStatus {
  IN_DEVELOPMENT
  DEPLOYING
  READY
  ERROR
}

/// One vibe-coded sandbox app, lazy-created on first deploy by its owning member.
model AiApp {
  id           Int         @id @default(autoincrement())
  uid          String      @unique @default(cuid())
  /// Owning member (no FK relation to keep the POC isolated from the Member model).
  memberUid    String
  /// Business key supplied in the deploy payload; unique per owner.
  appId        String
  name         String
  description  String?
  status       AiAppStatus @default(IN_DEVELOPMENT)
  notes        String?
  /// Hosting details returned by the sandbox runner on a successful deploy.
  url          String?
  httpUrl      String?
  host         String?
  port         Int?
  deploymentId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([memberUid, appId])
  @@index([memberUid])
  @@index([status])
}

/// Reusable per-member deploy token bundled into the starter kit ZIP.
model AiAppToken {
  id         Int       @id @default(autoincrement())
  uid        String    @unique @default(cuid())
  memberUid  String    @unique
  token      String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

enum AiAppEventType {
  KIT_DOWNLOADED
  DEPLOY_STARTED
  DEPLOY_SUCCEEDED
  DEPLOY_FAILED
}

/// Append-only audit log of AI Apps activity: who downloaded the kit and every
/// deploy attempt + outcome. One row per event (never updated) so the full
/// event flow is preserved. `AiApp.status` remains the current-state snapshot.
model AiAppEvent {
  id           Int            @id @default(autoincrement())
  uid          String         @unique @default(cuid())
  memberUid    String
  type         AiAppEventType
  /// Set for deploy events once the AiApp row exists (null for KIT_DOWNLOADED).
  appUid       String?
  /// Business key for deploy events (null for KIT_DOWNLOADED).
  appId        String?
  deploymentId String?
  /// Free-form context, e.g. the error detail on DEPLOY_FAILED.
  message      String?
  createdAt    DateTime       @default(now())

  @@index([memberUid])
  @@index([type])
  @@index([appUid])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Affinity CRM sidecars (read-only ingest from Affinity API — task 02)
// Separate from Team/Member core rows; optional FK when crosswalk succeeds.
// ---------------------------------------------------------------------------

enum AffinityIngestRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum AffinityEntityLinkMethod {
  AIRTABLE_REC_ID
  DOMAIN
  EMAIL
  AFFINITY_ID
  DIRECTORY_UID
  MANUAL
}

/// Audit row per Affinity pull/ingest execution.
model AffinityIngestRun {
  id           String                  @id @default(cuid())
  startedAt    DateTime                @default(now())
  finishedAt   DateTime?
  status       AffinityIngestRunStatus @default(RUNNING)
  /// e.g. companies | founders | full
  scope        String                  @db.VarChar(32)
  dryRun       Boolean                 @default(false)
  stats        Json?
  errorMessage String?                 @db.Text

  companies AffinityCompany[]
  persons   AffinityPerson[]

  @@index([startedAt])
  @@index([status])
}

/// Affinity organization (company) — teams/portfolio companies.
/// Upserted by affinityOrgId. Merges Portfolio Companies + Portfolio KPIs list fields.
model AffinityCompany {
  id  Int    @id @default(autoincrement())
  uid String @unique @default(cuid())

  /// Affinity organization id (entity.id from list-entries).
  affinityOrgId String @unique @db.VarChar(64)

  name    String
  domain  String?  @db.VarChar(255)
  domains String[] @default([])

  /// Builders Funnel Record ID (global field-3635409) — usually Airtable rec….
  buildersFunnelRecordId String? @db.VarChar(128)

  // --- Global CRM (Portfolio Companies) ---
  dealStatus         String?   @db.VarChar(120)
  tags               String[]  @default([])
  tokenStatus        String?   @db.VarChar(80)
  postMoneyValuation Decimal?  @db.Decimal(20, 2)
  exitDate           DateTime?
  deckLink           String?   @db.Text
  acceleratorProgram String?   @db.VarChar(120)
  investorType       String?   @db.VarChar(80)
  relationshipRoles  String[]  @default([])
  fundRelevance      String[]  @default([])

  // --- Affinity / Dealroom enrichment ---
  description       String?   @db.Text
  investmentStage   String?   @db.VarChar(120)
  industries        String[]  @default([])
  investors         String[]  @default([])
  yearFounded       Int?
  totalFundingUsd   Decimal?  @db.Decimal(20, 2)
  lastFundingUsd    Decimal?  @db.Decimal(20, 2)
  lastFundingDate   DateTime?
  linkedinUrl       String?   @db.Text
  employeeCount     Int?
  linkedinHeadcount Int?
  location          Json?

  // --- Portfolio KPIs (merged when org is on KPI list) ---
  priority                 String?   @db.VarChar(80)
  kpiListStatus            String?   @db.VarChar(80)
  mrr                      Decimal?  @db.Decimal(20, 2)
  revenueLtm               Decimal?  @db.Decimal(20, 2)
  monthlyBurn              Decimal?  @db.Decimal(20, 2)
  cashBalance              Decimal?  @db.Decimal(20, 2)
  runwayMonths             Int?
  teamFte                  Int?
  totalUsers               Int?
  maus                     Int?
  daus                     Int?
  initialInvestmentUsd     Decimal?  @db.Decimal(20, 2)
  valuationAtInvestmentUsd Decimal?  @db.Decimal(20, 2)
  latestPostMoneyUsd       Decimal?  @db.Decimal(20, 2)
  fundedVia                String[]  @default([])
  kpiLastUpdateAt          DateTime?
  planToFundraise6Mo       String?   @db.VarChar(80)

  // --- Relationship intelligence (normalized dates) ---
  lastContactAt        DateTime?
  lastEmailAt          DateTime?
  firstEmailAt         DateTime?
  lastEventAt          DateTime?
  firstEventAt         DateTime?
  nextEventAt          DateTime?
  /// Person ref: { id, firstName, lastName, primaryEmailAddress, type }
  sourceOfIntroduction Json?

  /// Affinity person ids from `persons` field + v1 org.person_ids (deduped).
  linkedPersonIds Int[] @default([])

  // --- Optional Directory link ---
  teamUid        String?                   @unique
  team           Team?                     @relation(fields: [teamUid], references: [uid], onDelete: SetNull)
  linkMethod     AffinityEntityLinkMethod?
  linkConfidence Float?
  linkedAt       DateTime?

  listMemberships     AffinityListMembership[]
  personOrganizations AffinityPersonOrganization[] @relation("AffinityCompanyPersonOrgs")
  primaryForPersons   AffinityPerson[]             @relation("AffinityPersonPrimaryCompany")

  /// All list-entry field values keyed by Affinity field id.
  rawFields         Json
  /// Optional v1 GET /organizations/{id} payload.
  rawV1Organization Json?

  pulledAt        DateTime           @default(now())
  lastIngestRunId String?
  lastIngestRun   AffinityIngestRun? @relation(fields: [lastIngestRunId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain])
  @@index([buildersFunnelRecordId])
  @@index([dealStatus])
  @@index([priority])
  @@index([teamUid])
  @@index([lastIngestRunId])
}

/// Affinity person — founders and other people on founder lists.
model AffinityPerson {
  id  Int    @id @default(autoincrement())
  uid String @unique @default(cuid())

  /// Affinity person id (entity.id from list-entries).
  affinityPersonId String @unique @db.VarChar(64)

  firstName      String?  @db.VarChar(120)
  lastName       String?  @db.VarChar(120)
  fullName       String?  @db.VarChar(240)
  primaryEmail   String?  @db.VarChar(320)
  emailAddresses String[] @default([])

  /// field-4173262 — Airtable rec…, email, or rarely Directory uid.
  buildersFunnelRecordId String?  @db.VarChar(128)
  telegram               String?  @db.VarChar(120)
  linkedinUrl            String?  @db.Text
  phoneNumbers           String[] @default([])

  currentJobTitle               String?  @db.VarChar(240)
  currentOrganizationName       String?  @db.VarChar(240)
  currentOrganizationAffinityId String?  @db.VarChar(64)
  industries                    String[] @default([])
  location                      Json?

  // --- CRM scoring / segmentation ---
  relationshipTiers String[] @default([])
  relationshipRoles String[] @default([])
  fundRelevance     String[] @default([])
  investorTypes     String[] @default([])
  stagePreference   String?  @db.Text
  sectorFocus       String?  @db.Text
  dataSources       String[] @default([])
  dataQuality       String?  @db.Text
  engagementScore   Float?
  relationshipScore Float?
  qualityScore      Float?
  keyContact        String?  @db.VarChar(240)
  standing          String?  @db.VarChar(80)
  listStatus        String?  @db.VarChar(80)
  gender            String?  @db.VarChar(40)

  // --- Relationship intelligence ---
  lastContactAt        DateTime?
  lastEmailAt          DateTime?
  firstEmailAt         DateTime?
  lastEventAt          DateTime?
  firstEventAt         DateTime?
  nextEventAt          DateTime?
  sourceOfIntroduction Json?

  // --- Optional Directory links ---
  memberUid      String?                   @unique
  member         Member?                   @relation(fields: [memberUid], references: [uid], onDelete: SetNull)
  linkMethod     AffinityEntityLinkMethod?
  linkConfidence Float?
  linkedAt       DateTime?

  /// Best-effort company link from current organization / companies[] field.
  primaryCompanyUid String?
  primaryCompany    AffinityCompany? @relation("AffinityPersonPrimaryCompany", fields: [primaryCompanyUid], references: [uid], onDelete: SetNull)

  listMemberships AffinityListMembership[]
  organizations   AffinityPersonOrganization[]

  rawFields   Json
  /// Optional v1 GET /persons/{id} payload (emails, interaction_dates, …).
  rawV1Person Json?

  pulledAt        DateTime           @default(now())
  lastIngestRunId String?
  lastIngestRun   AffinityIngestRun? @relation(fields: [lastIngestRunId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([primaryEmail])
  @@index([buildersFunnelRecordId])
  @@index([currentOrganizationAffinityId])
  @@index([memberUid])
  @@index([primaryCompanyUid])
  @@index([lastIngestRunId])
}

/// Person ↔ company edges from Affinity `companies` / org associations.
model AffinityPersonOrganization {
  id Int @id @default(autoincrement())

  personUid  String
  person     AffinityPerson  @relation(fields: [personUid], references: [uid], onDelete: Cascade)
  companyUid String
  company    AffinityCompany @relation("AffinityCompanyPersonOrgs", fields: [companyUid], references: [uid], onDelete: Cascade)

  /// Affinity org id denormalized for upserts without joins.
  affinityOrgId    String  @db.VarChar(64)
  affinityPersonId String  @db.VarChar(64)
  isCurrent        Boolean @default(false)
  /// Job title at this org when known.
  jobTitle         String? @db.VarChar(240)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([personUid, companyUid])
  @@index([affinityOrgId])
  @@index([affinityPersonId])
}

/// Which Affinity lists an entity appears on (companies can be on Companies + KPIs).
model AffinityListMembership {
  id Int @id @default(autoincrement())

  affinityListId      Int
  affinityListEntryId Int    @unique
  listName            String @db.VarChar(200)

  companyUid String?
  company    AffinityCompany? @relation(fields: [companyUid], references: [uid], onDelete: Cascade)
  personUid  String?
  person     AffinityPerson?  @relation(fields: [personUid], references: [uid], onDelete: Cascade)

  /// List-specific field subset (Status, Owners, Amount, …) keyed by field id.
  listFields Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([affinityListId])
  @@index([companyUid])
  @@index([personUid])
}
